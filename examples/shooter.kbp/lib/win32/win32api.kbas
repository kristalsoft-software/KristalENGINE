# ── Pencere ──
func int    WIN_FOREGROUND()             { return kbas_GetForegroundWindow(); }
func int    WIN_DESKTOP()                { return kbas_GetDesktopWindow(); }
func int    WIN_FIND(string cls, string title) { return kbas_FindWindow(cls, title); }
func string WIN_TITLE(int w)             { return kbas_GetWindowText(w); }
func bool   WIN_SET_TITLE(string t)      { return kbas_SetForegroundTitle(t); }
func bool   WIN_SHOW(int w, int mode)    { return kbas_ShowWindow(w, mode); }
func bool   WIN_MOVE(int w, int x, int y, int ww, int h) { return kbas_MoveWindow(w, x, y, ww, h, true); }
func int    WIN_X(int w)                 { return kbas_GetWindowLeft(w); }
func int    WIN_Y(int w)                 { return kbas_GetWindowTop(w); }
func int    WIN_W(int w)                 { return kbas_GetWindowWidth(w); }
func int    WIN_H(int w)                 { return kbas_GetWindowHeight(w); }
func bool   WIN_VISIBLE(int w)           { return kbas_IsWindowVisible(w); }
func bool   WIN_TOPMOST(int w)           { return kbas_BringWindowToTop(w); }
func bool   WIN_ENABLE(int w, bool e)    { return kbas_EnableWindow(w, e); }
func bool   WIN_FLASH(int w)             { return kbas_FlashWindow(w, true); }
func int    WIN_AT_POINT(int x, int y)   { return kbas_WindowFromPoint(x, y); }
func void   WIN_FREE(int w)              { kbas_FreeHwnd(w); }
func int  WIN_GET_LONG(int w, int idx)                             { return kbas_GetWindowLong(w, idx); }
func int  WIN_SET_LONG(int w, int idx, int val)                    { return kbas_SetWindowLong(w, idx, val); }
func bool WIN_POS(int w, int x, int y, int cx, int cy, int flags)  { return kbas_SetWindowPos(w, x, y, cx, cy, flags); }
func bool WIN_SET_LAYERED(int w, int r, int g, int b, int alpha, int flags) { return kbas_SetLayeredWindowAttributes(w, r, g, b, alpha, flags); }

# ── Diyalog ──
func int  DIALOG(string text, string caption, int type) { return kbas_MessageBox(text, caption, type); }
func void DIALOG_OK(string text, string caption)    { kbas_MessageBox(text, caption, MB_OK() | MB_ICONINFO()); }
func void DIALOG_ERROR(string text, string caption) { kbas_MessageBox(text, caption, MB_OK() | MB_ICONERROR()); }
func void DIALOG_WARN(string text, string caption)  { kbas_MessageBox(text, caption, MB_OK() | MB_ICONWARNING()); }
func bool DIALOG_YESNO(string text, string caption) { return kbas_MessageBox(text, caption, MB_YESNO() | MB_ICONQUESTION()) == IDYES(); }
func void BEEP_SYS(int type)  { kbas_MessageBeep(type); }
func bool BEEP_HZ(int f, int ms) { return kbas_Beep(f, ms); }

# ── GDI ──
func int  GDI_GET_DC(int w)               { return kbas_GetDC(w); }
func bool GDI_RELEASE_DC(int w, int dc)   { return kbas_ReleaseDC(w, dc); }
func int  GDI_COMPAT_DC(int dc)           { return kbas_CreateCompatibleDC(dc); }
func bool GDI_DELETE_DC(int dc)           { return kbas_DeleteDC(dc); }
func int  GDI_COMPAT_BMP(int dc, int w, int h) { return kbas_CreateCompatibleBitmap(dc, w, h); }
func int  GDI_SELECT(int dc, int obj)     { return kbas_SelectObject(dc, obj); }
func bool GDI_DELETE(int obj)             { return kbas_DeleteObject(obj); }
func bool GDI_BLIT(int ddc, int dx, int dy, int w, int h, int sdc, int sx, int sy, int rop) { return kbas_BitBlt(ddc, dx, dy, w, h, sdc, sx, sy, rop); }
func int  GDI_BRUSH(int r, int g, int b)  { return kbas_CreateSolidBrush(r, g, b); }
func int  GDI_HATCH(int s, int r, int g, int b) { return kbas_CreateHatchBrush(s, r, g, b); }
func int  GDI_PEN(int s, int w, int r, int g, int b) { return kbas_CreatePen(s, w, r, g, b); }
func int  GDI_FONT(int h, int bold, bool italic, string name) { return kbas_CreateFont(h, 0, bold, italic, false, false, name); }
func bool GDI_PIXEL(int dc, int x, int y, int r, int g, int b) { return kbas_SetPixel(dc, x, y, r, g, b) >= 0; }
func bool GDI_MOVE(int dc, int x, int y) { return kbas_MoveTo(dc, x, y); }
func bool GDI_LINE(int dc, int x, int y) { return kbas_LineTo(dc, x, y); }
func bool GDI_RECT(int dc, int l, int t, int r, int b) { return kbas_Rectangle(dc, l, t, r, b); }
func bool GDI_ELLIPSE(int dc, int l, int t, int r, int b) { return kbas_Ellipse(dc, l, t, r, b); }
func bool GDI_FILL(int dc, int l, int t, int r, int b, int br) { return kbas_FillRect(dc, l, t, r, b, br); }
func bool GDI_TEXT(int dc, int x, int y, string text) { return kbas_TextOut(dc, x, y, text); }
func void GDI_TEXT_COLOR(int dc, int r, int g, int b) { kbas_SetTextColor(dc, r, g, b); }
func void GDI_BK_COLOR(int dc, int r, int g, int b)   { kbas_SetBkColor(dc, r, g, b); }
func void GDI_BK_MODE(int dc, int mode)               { kbas_SetBkMode(dc, mode); }
func int  SCREEN_METRIC(int idx)   { return kbas_GetSystemMetrics(idx); }

