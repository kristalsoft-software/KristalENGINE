/* ════════════════════════════════════════════════
   15. GÜÇ YÖNETİMİ  (kernel32 + user32)
   ════════════════════════════════════════════════ */

/* Sistem kapatma / yeniden başlatma / oturumu kapat */
bool kbas_Shutdown()  {
    HANDLE tok; OpenProcessToken(GetCurrentProcess(), TOKEN_ADJUST_PRIVILEGES|TOKEN_QUERY, &tok);
    TOKEN_PRIVILEGES tp = {1}; LookupPrivilegeValueA(NULL, SE_SHUTDOWN_NAME, &tp.Privileges[0].Luid);
    tp.Privileges[0].Attributes = SE_PRIVILEGE_ENABLED; AdjustTokenPrivileges(tok, FALSE, &tp, 0, NULL, NULL);
    return (bool)ExitWindowsEx(EWX_SHUTDOWN | EWX_FORCE, SHTDN_REASON_MAJOR_OTHER);
}
bool kbas_Reboot() {
    HANDLE tok; OpenProcessToken(GetCurrentProcess(), TOKEN_ADJUST_PRIVILEGES|TOKEN_QUERY, &tok);
    TOKEN_PRIVILEGES tp = {1}; LookupPrivilegeValueA(NULL, SE_SHUTDOWN_NAME, &tp.Privileges[0].Luid);
    tp.Privileges[0].Attributes = SE_PRIVILEGE_ENABLED; AdjustTokenPrivileges(tok, FALSE, &tp, 0, NULL, NULL);
    return (bool)ExitWindowsEx(EWX_REBOOT | EWX_FORCE, SHTDN_REASON_MAJOR_OTHER);
}
bool kbas_Logoff() {
    return (bool)ExitWindowsEx(EWX_LOGOFF | EWX_FORCE, SHTDN_REASON_MAJOR_OTHER);
}
bool kbas_LockWorkstation2() {
    return (bool)LockWorkStation();
}

/* Güç durumu */
bool kbas_IsOnBattery() {
    SYSTEM_POWER_STATUS ps;
    GetSystemPowerStatus(&ps);
    return ps.ACLineStatus == 0;
}
int kbas_BatteryPercent() {
    SYSTEM_POWER_STATUS ps;
    GetSystemPowerStatus(&ps);
    return (ps.BatteryLifePercent == 255) ? -1 : (int)ps.BatteryLifePercent;
}

