int kbas_GetLastError2() {
    return (int)GetLastError();
}

void kbas_SetLastError2(int code) {
    SetLastError((DWORD)code);
}

char* kbas_GetErrorMessage(int code) {
    FormatMessageA(FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS,
                   NULL, (DWORD)code, 0, g_strbuf, KBAS_STRBUF_SIZE, NULL);
    /* Satır sonu temizle */
    for (int i = (int)strlen(g_strbuf) - 1; i >= 0 && (g_strbuf[i]=='\n'||g_strbuf[i]=='\r'); i--)
        g_strbuf[i] = 0;
    return kbc_str_dup(g_strbuf);
}

char* kbas_GetLastErrorMessage() {
    return kbas_GetErrorMessage((int)GetLastError());
}
