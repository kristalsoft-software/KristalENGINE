static SYSTEMTIME kbas__st;
static void kbas__update_time() { GetLocalTime(&kbas__st); }

int kbas_GetYear()   { kbas__update_time(); return (int)kbas__st.wYear; }
int kbas_GetMonth()  { kbas__update_time(); return (int)kbas__st.wMonth; }
int kbas_GetDay()    { kbas__update_time(); return (int)kbas__st.wDay; }
