@INDICATE "-luser32"
@INDICATE "-lgdi32"
@INDICATE "-lkernel32"
@INDICATE "-lwinmm"
@INDICATE "-ladvapi32"
@INDICATE "-lshell32"
@IMPORT "user32.dll"
@IMPORT "gdi32.dll"
@IMPORT "kernel32.dll"
@IMPORT "winmm.dll"
@IMPORT "advapi32.dll"
@IMPORT "shell32.dll"

external C """
/* =================================================================
   WIN32 API - KristalBASIC Tam Binding
   Kütüphaneler: user32, gdi32, kernel32, winmm, advapi32, shell32
   ================================================================= */

#ifndef __cplusplus
#define bool _Bool
#define true 1
#define false 0
#endif

#define WIN32_LEAN_AND_MEAN
#include <windows.h>

#include <mmsystem.h>
#include <shellapi.h>
#include <shlobj.h>
#include <tlhelp32.h>
#include <stdint.h>
#include <stdio.h>
#include <string.h>

/* ─────────────────────────────────────────────
   İÇ HANDLE TABLOLARI
   Tüm Win32 handle'ları güvenli int indekslere
   dönüştürülür. 32/64-bit uyumlu.
   ───────────────────────────────────────────── */
#define KBAS_MAX_HANDLES  512
#define KBAS_MAX_KEYS      64
#define KBAS_MAX_DC        64
#define KBAS_MAX_GDIOBJ   512
#define KBAS_MAX_HWND      64
#define KBAS_STRBUF_SIZE 8192

static HANDLE  g_handles[KBAS_MAX_HANDLES] = {0};
static HKEY    g_regkeys[KBAS_MAX_KEYS]    = {0};
static HDC     g_dc     [KBAS_MAX_DC]      = {0};
static HGDIOBJ g_gdiobj [KBAS_MAX_GDIOBJ] = {0};
static HWND    g_hwnd   [KBAS_MAX_HWND]   = {0};
static char    g_strbuf [KBAS_STRBUF_SIZE] = {0};

static wchar_t* kbas__utf8_to_utf16(const char* utf8) {
    if (!utf8) return NULL;
    int wlen = MultiByteToWideChar(CP_UTF8, 0, utf8, -1, NULL, 0);
    if (wlen == 0) return NULL;
    wchar_t* wstr = (wchar_t*)malloc(wlen * sizeof(wchar_t));
    MultiByteToWideChar(CP_UTF8, 0, utf8, -1, wstr, wlen);
    return wstr;
}

static int kbas__alloc_handle(HANDLE h) {
    if (!h || h == INVALID_HANDLE_VALUE) return -1;
    for (int i = 1; i < KBAS_MAX_HANDLES; i++) {
        if (!g_handles[i]) { g_handles[i] = h; return i; }
    }
    return -1;
}
static HANDLE kbas__get_handle(int idx) {
    if (idx < 1 || idx >= KBAS_MAX_HANDLES) return NULL;
    return g_handles[idx];
}
static int kbas__alloc_dc(HDC dc) {
    if (!dc) return -1;
    for (int i = 1; i < KBAS_MAX_DC; i++) {
        if (!g_dc[i]) { g_dc[i] = dc; return i; }
    }
    return -1;
}
static HDC kbas__get_dc(int idx) {
    if (idx < 1 || idx >= KBAS_MAX_DC) return NULL;
    return g_dc[idx];
}
static int kbas__alloc_gdi(HGDIOBJ obj) {
    if (!obj) return -1;
    for (int i = 1; i < KBAS_MAX_GDIOBJ; i++) {
        if (!g_gdiobj[i]) { g_gdiobj[i] = obj; return i; }
    }
    return -1;
}
static HGDIOBJ kbas__get_gdi(int idx) {
    if (idx < 1 || idx >= KBAS_MAX_GDIOBJ) return NULL;
    return g_gdiobj[idx];
}
static int kbas__alloc_hwnd(HWND wnd) {
    if (!wnd) return -1;
    for (int i = 1; i < KBAS_MAX_HWND; i++) {
        if (!g_hwnd[i]) { g_hwnd[i] = wnd; return i; }
    }
    return -1;
}
static HWND kbas__get_hwnd(int idx) {
    if (idx < 1 || idx >= KBAS_MAX_HWND) return NULL;
    return g_hwnd[idx];
}
static int kbas__alloc_key(HKEY key) {
    if (!key) return -1;
    for (int i = 1; i < KBAS_MAX_KEYS; i++) {
        if (!g_regkeys[i]) { g_regkeys[i] = key; return i; }
    }
    return -1;
}
static HKEY kbas__get_key(int idx) {
    if (idx < 1 || idx >= KBAS_MAX_KEYS) return NULL;
    return g_regkeys[idx];
}

/* ════════════════════════════════════════════════
   1. PENCERE YÖNETİMİ  (user32)
   ════════════════════════════════════════════════ */

/* Ön plan penceresini döndürür (indeks) */
int kbas_GetForegroundWindow() {
    HWND w = GetForegroundWindow();
    return kbas__alloc_hwnd(w);
}

/* Masaüstü penceresini döndürür (indeks) */
int kbas_GetDesktopWindow() {
    return kbas__alloc_hwnd(GetDesktopWindow());
}

/* Sınıf ve başlık adına göre pencere bul (indeks; -1 = bulunamadı) */
int kbas_FindWindow(char* className, char* title) {
    wchar_t* w_class = kbas__utf8_to_utf16(className);
    wchar_t* w_title = kbas__utf8_to_utf16(title);
    HWND w = FindWindowW(
        w_class && wcslen(w_class) ? w_class : NULL,
        w_title && wcslen(w_title) ? w_title : NULL);
    if (w_class) free(w_class);
    if (w_title) free(w_title);
    return kbas__alloc_hwnd(w);
}

/* Alt pencere ara */
int kbas_FindWindowEx(int parentIdx, int childAfterIdx, char* className, char* title) {
    HWND parent     = kbas__get_hwnd(parentIdx);
    HWND childAfter = kbas__get_hwnd(childAfterIdx);
    wchar_t* w_class = kbas__utf8_to_utf16(className);
    wchar_t* w_title = kbas__utf8_to_utf16(title);
    HWND w = FindWindowExW(parent, childAfter,
        w_class && wcslen(w_class) ? w_class : NULL,
        w_title && wcslen(w_title) ? w_title : NULL);
    if (w_class) free(w_class);
    if (w_title) free(w_title);
    return kbas__alloc_hwnd(w);
}

/* Pencere başlığını oku */
char* kbas_GetWindowText(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    if (!w) { g_strbuf[0] = 0; return kbc_str_dup(g_strbuf); }
    GetWindowTextA(w, g_strbuf, KBAS_STRBUF_SIZE);
    return kbc_str_dup(g_strbuf);
}

/* Pencere başlığını değiştir */
bool kbas_SetWindowText(int hwndIdx, char* text) {
    HWND w = kbas__get_hwnd(hwndIdx);
    if (!w) return false;
    wchar_t* w_text = kbas__utf8_to_utf16(text);
    bool ret = (bool)SetWindowTextW(w, w_text ? w_text : L"");
    if (w_text) free(w_text);
    return ret;
}

/* Ön plan penceresinin başlığını değiştir (raylib kolaylığı) */
bool kbas_SetForegroundTitle(char* text) {
    wchar_t* w_text = kbas__utf8_to_utf16(text);
    bool ret = (bool)SetWindowTextW(GetForegroundWindow(), w_text ? w_text : L"");
    if (w_text) free(w_text);
    return ret;
}

/* ShowWindow */
bool kbas_ShowWindow(int hwndIdx, int cmdShow) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)ShowWindow(w, cmdShow) : false;
}

/* MoveWindow */
bool kbas_MoveWindow(int hwndIdx, int x, int y, int w, int h, bool repaint) {
    HWND wnd = kbas__get_hwnd(hwndIdx);
    return wnd ? (bool)MoveWindow(wnd, x, y, w, h, repaint) : false;
}

/* SetWindowPos */
bool kbas_SetWindowPos(int hwndIdx, int x, int y, int cx, int cy, int flags) {
    HWND wnd = kbas__get_hwnd(hwndIdx);
    return wnd ? (bool)SetWindowPos(wnd, NULL, x, y, cx, cy, (UINT)flags) : false;
}

/* GetWindowRect: sol/üst/sağ/alt ayrı fonksiyonlar */
static RECT kbas__winrect(int hwndIdx) {
    RECT r = {0};
    HWND w = kbas__get_hwnd(hwndIdx);
    if (w) GetWindowRect(w, &r);
    return r;
}
int kbas_GetWindowLeft  (int idx) { return (int)kbas__winrect(idx).left;   }
int kbas_GetWindowTop   (int idx) { return (int)kbas__winrect(idx).top;    }
int kbas_GetWindowRight (int idx) { return (int)kbas__winrect(idx).right;  }
int kbas_GetWindowBottom(int idx) { return (int)kbas__winrect(idx).bottom; }
int kbas_GetWindowWidth (int idx) { RECT r = kbas__winrect(idx); return r.right  - r.left; }
int kbas_GetWindowHeight(int idx) { RECT r = kbas__winrect(idx); return r.bottom - r.top;  }

/* GetClientRect */
static RECT kbas__clientrect(int hwndIdx) {
    RECT r = {0};
    HWND w = kbas__get_hwnd(hwndIdx);
    if (w) GetClientRect(w, &r);
    return r;
}
int kbas_GetClientWidth (int idx) { RECT r = kbas__clientrect(idx); return r.right  - r.left; }
int kbas_GetClientHeight(int idx) { RECT r = kbas__clientrect(idx); return r.bottom - r.top;  }

/* Pencere görünür mü? */
bool kbas_IsWindowVisible(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)IsWindowVisible(w) : false;
}

/* Pencere etkin mi? */
bool kbas_IsWindowEnabled(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)IsWindowEnabled(w) : false;
}

/* Pencereyi etkinleştir / devre dışı bırak */
bool kbas_EnableWindow(int hwndIdx, bool enable) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)EnableWindow(w, enable) : false;
}

/* Ön plana getir */
bool kbas_SetForegroundWindow(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)SetForegroundWindow(w) : false;
}

/* En üste getir */
bool kbas_BringWindowToTop(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)BringWindowToTop(w) : false;
}

/* Görev çubuğunda pencereyi flaşlat */
bool kbas_FlashWindow(int hwndIdx, bool invert) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)FlashWindow(w, invert) : false;
}

/* Ebeveyn penceresi indeksi */
int kbas_GetParent(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? kbas__alloc_hwnd(GetParent(w)) : -1;
}

/* GetWindowLongPtr (stil, kimlik vb.) */
int kbas_GetWindowLong(int hwndIdx, int index) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (int)GetWindowLongPtrA(w, index) : 0;
}

/* SetWindowLongPtr */
int kbas_SetWindowLong(int hwndIdx, int index, int value) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (int)SetWindowLongPtrA(w, index, (LONG_PTR)value) : 0;
}

/* Pencere işleminin PID'ini al */
int kbas_GetWindowProcessId(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    if (!w) return 0;
    DWORD pid = 0;
    GetWindowThreadProcessId(w, &pid);
    return (int)pid;
}

/* Noktadaki pencere */
int kbas_WindowFromPoint(int x, int y) {
    POINT p = {x, y};
    return kbas__alloc_hwnd(WindowFromPoint(p));
}

/* Geçersiz kıl (yeniden çizim tetikle) */
bool kbas_InvalidateWindow(int hwndIdx) {
    HWND w = kbas__get_hwnd(hwndIdx);
    return w ? (bool)InvalidateRect(w, NULL, TRUE) : false;
}

/* Kayıtlı hwnd indeksini serbest bırak */
void kbas_FreeHwnd(int hwndIdx) {
    if (hwndIdx >= 1 && hwndIdx < KBAS_MAX_HWND)
        g_hwnd[hwndIdx] = NULL;
}

/* Katmanlı pencere: renk anahtarı ve/veya alfa şeffaflık */
bool kbas_SetLayeredWindowAttributes(int hwndIdx, int r, int g, int b, int alpha, int flags) {
    HWND w = kbas__get_hwnd(hwndIdx);
    if (!w) return false;
    return (bool)SetLayeredWindowAttributes(
        w, RGB((BYTE)r, (BYTE)g, (BYTE)b), (BYTE)alpha, (DWORD)flags
    );
}

/* ════════════════════════════════════════════════
   2. MESAJ & DİYALOG  (user32)
   ════════════════════════════════════════════════ */

int  kbas_MessageBox(char* text, char* caption, int type) {
    wchar_t* w_text = kbas__utf8_to_utf16(text);
    wchar_t* w_caption = kbas__utf8_to_utf16(caption);
    int ret = MessageBoxW(NULL, w_text ? w_text : L"", w_caption ? w_caption : L"", (UINT)type);
    if (w_text) free(w_text);
    if (w_caption) free(w_caption);
    return ret;
}
void kbas_MessageBeep(int type) {
    MessageBeep((UINT)type);
}
bool kbas_Beep(int freq, int durationMs) {
    return (bool)Beep((DWORD)freq, (DWORD)durationMs);
}

/* Basit girdi kutusu - global strbuf'a yazar, NULL = iptal */
char* kbas_InputBox(char* title, char* prompt, char* defaultVal) {
    /* Not: Win32'de native InputBox yok; bu versiyon sabit bir dialog kurar */
    /* Daha gelişmiş bir sürüm için özel pencere oluşturmak gerekir */
    strncpy(g_strbuf, defaultVal ? defaultVal : "", KBAS_STRBUF_SIZE - 1);
    /* Şimdilik default değeri döndürür - MessageBox ile onay al */
    wchar_t* w_prompt = kbas__utf8_to_utf16(prompt);
    wchar_t* w_title = kbas__utf8_to_utf16(title);
    int r = MessageBoxW(NULL, w_prompt ? w_prompt : L"", w_title ? w_title : L"", MB_OKCANCEL | MB_ICONQUESTION);
    if (w_prompt) free(w_prompt);
    if (w_title) free(w_title);
    return (r == IDOK) ? g_strbuf : NULL;
}

/* PostQuitMessage */
void kbas_PostQuitMessage(int exitCode) {
    PostQuitMessage(exitCode);
}

/* ════════════════════════════════════════════════
   3. GDI ÇİZİM  (gdi32 + user32)
   ════════════════════════════════════════════════ */

/* Pencere DC al */
int kbas_GetDC(int hwndIdx) {
    HWND w = hwndIdx == 0 ? GetForegroundWindow() : kbas__get_hwnd(hwndIdx);
    return kbas__alloc_dc(GetDC(w));
}

/* DC serbest bırak */
bool kbas_ReleaseDC(int hwndIdx, int dcIdx) {
    HWND w  = hwndIdx == 0 ? GetForegroundWindow() : kbas__get_hwnd(hwndIdx);
    HDC  dc = kbas__get_dc(dcIdx);
    if (!dc) return false;
    bool ok = (bool)ReleaseDC(w, dc);
    g_dc[dcIdx] = NULL;
    return ok;
}

/* Uyumlu DC oluştur (offscreen render için) */
int kbas_CreateCompatibleDC(int dcIdx) {
    HDC dc = kbas__get_dc(dcIdx);
    return kbas__alloc_dc(CreateCompatibleDC(dc));
}

/* DC sil */
bool kbas_DeleteDC(int dcIdx) {
    HDC dc = kbas__get_dc(dcIdx);
    if (!dc) return false;
    bool ok = (bool)DeleteDC(dc);
    g_dc[dcIdx] = NULL;
    return ok;
}

/* Uyumlu bitmap oluştur */
int kbas_CreateCompatibleBitmap(int dcIdx, int w, int h) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? kbas__alloc_gdi((HGDIOBJ)CreateCompatibleBitmap(dc, w, h)) : -1;
}

/* GDI nesnesini DC'ye seç; önceki nesnenin indeksini döndürür */
int kbas_SelectObject(int dcIdx, int objIdx) {
    HDC     dc  = kbas__get_dc(dcIdx);
    HGDIOBJ obj = kbas__get_gdi(objIdx);
    if (!dc || !obj) return -1;
    return kbas__alloc_gdi(SelectObject(dc, obj));
}

/* GDI nesnesini sil */
bool kbas_DeleteObject(int objIdx) {
    HGDIOBJ obj = kbas__get_gdi(objIdx);
    if (!obj) return false;
    bool ok = (bool)DeleteObject(obj);
    g_gdiobj[objIdx] = NULL;
    return ok;
}

/* BitBlt (kaynak DC → hedef DC kopyala) */
bool kbas_BitBlt(int dstDcIdx, int dstX, int dstY, int w, int h,
                 int srcDcIdx, int srcX, int srcY, int rop) {
    HDC dst = kbas__get_dc(dstDcIdx);
    HDC src = kbas__get_dc(srcDcIdx);
    return (dst && src) ? (bool)BitBlt(dst, dstX, dstY, w, h, src, srcX, srcY, (DWORD)rop) : false;
}

/* StretchBlt */
bool kbas_StretchBlt(int dstDcIdx, int dstX, int dstY, int dstW, int dstH,
                     int srcDcIdx, int srcX, int srcY, int srcW, int srcH, int rop) {
    HDC dst = kbas__get_dc(dstDcIdx);
    HDC src = kbas__get_dc(srcDcIdx);
    return (dst && src) ? (bool)StretchBlt(dst, dstX, dstY, dstW, dstH,
                                            src, srcX, srcY, srcW, srcH, (DWORD)rop) : false;
}

/* Fırça oluştur (RGB renk) */
int kbas_CreateSolidBrush(int r, int g, int b) {
    return kbas__alloc_gdi((HGDIOBJ)CreateSolidBrush(RGB(r, g, b)));
}

/* Taralı fırça */
int kbas_CreateHatchBrush(int style, int r, int g, int b) {
    return kbas__alloc_gdi((HGDIOBJ)CreateHatchBrush(style, RGB(r, g, b)));
}

/* Kalem oluştur */
int kbas_CreatePen(int style, int width, int r, int g, int b) {
    return kbas__alloc_gdi((HGDIOBJ)CreatePen(style, width, RGB(r, g, b)));
}

/* Font oluştur */
int kbas_CreateFont(int height, int width, int weight, bool italic,
                    bool underline, bool strikeout, char* faceName) {
    HFONT f = CreateFontA(height, width, 0, 0, weight,
                          italic, underline, strikeout,
                          DEFAULT_CHARSET, OUT_DEFAULT_PRECIS,
                          CLIP_DEFAULT_PRECIS, DEFAULT_QUALITY,
                          DEFAULT_PITCH | FF_DONTCARE, faceName);
    return kbas__alloc_gdi((HGDIOBJ)f);
}

/* Piksel yaz */
int kbas_SetPixel(int dcIdx, int x, int y, int r, int g, int b) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (int)SetPixel(dc, x, y, RGB(r, g, b)) : -1;
}

/* Piksel oku - R,G,B ayrı fonksiyonlar */
static COLORREF kbas__getpixel(int dcIdx, int x, int y) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? GetPixel(dc, x, y) : CLR_INVALID;
}
int kbas_GetPixelR(int dcIdx, int x, int y) { return (int)GetRValue(kbas__getpixel(dcIdx,x,y)); }
int kbas_GetPixelG(int dcIdx, int x, int y) { return (int)GetGValue(kbas__getpixel(dcIdx,x,y)); }
int kbas_GetPixelB(int dcIdx, int x, int y) { return (int)GetBValue(kbas__getpixel(dcIdx,x,y)); }

/* MoveTo & LineTo */
bool kbas_MoveTo(int dcIdx, int x, int y) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)MoveToEx(dc, x, y, NULL) : false;
}
bool kbas_LineTo(int dcIdx, int x, int y) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)LineTo(dc, x, y) : false;
}

/* Dikdörtgen */
bool kbas_Rectangle(int dcIdx, int l, int t, int r, int b) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)Rectangle(dc, l, t, r, b) : false;
}

/* Elips */
bool kbas_Ellipse(int dcIdx, int l, int t, int r, int b) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)Ellipse(dc, l, t, r, b) : false;
}

/* Yuvarlatılmış dikdörtgen */
bool kbas_RoundRect(int dcIdx, int l, int t, int r, int b, int ellipseW, int ellipseH) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)RoundRect(dc, l, t, r, b, ellipseW, ellipseH) : false;
}

/* Dikdörtgeni fırçayla doldur */
bool kbas_FillRect(int dcIdx, int l, int t, int r, int b, int brushIdx) {
    HDC    dc  = kbas__get_dc(dcIdx);
    HBRUSH br  = (HBRUSH)kbas__get_gdi(brushIdx);
    if (!dc || !br) return false;
    RECT rc = {l, t, r, b};
    return (bool)FillRect(dc, &rc, br);
}

/* Dikdörtgen çerçevesi çiz */
bool kbas_FrameRect(int dcIdx, int l, int t, int r, int b, int brushIdx) {
    HDC    dc = kbas__get_dc(dcIdx);
    HBRUSH br = (HBRUSH)kbas__get_gdi(brushIdx);
    if (!dc || !br) return false;
    RECT rc = {l, t, r, b};
    return (bool)FrameRect(dc, &rc, br);
}

/* Metin çiz */
bool kbas_TextOut(int dcIdx, int x, int y, char* text) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)TextOutA(dc, x, y, text, (int)strlen(text)) : false;
}

/* Metin rengi ayarla */
int kbas_SetTextColor(int dcIdx, int r, int g, int b) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (int)SetTextColor(dc, RGB(r,g,b)) : -1;
}

/* Arka plan rengi ayarla */
int kbas_SetBkColor(int dcIdx, int r, int g, int b) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (int)SetBkColor(dc, RGB(r,g,b)) : -1;
}

/* Arka plan modu (TRANSPARENT=1, OPAQUE=2) */
int kbas_SetBkMode(int dcIdx, int mode) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? SetBkMode(dc, mode) : 0;
}

/* Metin boyutu ölç */
int kbas_GetTextWidth(int dcIdx, char* text) {
    HDC dc = kbas__get_dc(dcIdx);
    if (!dc) return 0;
    SIZE s;
    GetTextExtentPoint32A(dc, text, (int)strlen(text), &s);
    return (int)s.cx;
}
int kbas_GetTextHeight(int dcIdx, char* text) {
    HDC dc = kbas__get_dc(dcIdx);
    if (!dc) return 0;
    SIZE s;
    GetTextExtentPoint32A(dc, text, (int)strlen(text), &s);
    return (int)s.cy;
}

/* PatBlt - fırçayla dikdörtgen doldur */
bool kbas_PatBlt(int dcIdx, int x, int y, int w, int h, int rop) {
    HDC dc = kbas__get_dc(dcIdx);
    return dc ? (bool)PatBlt(dc, x, y, w, h, (DWORD)rop) : false;
}

/* Sistem metrik */
int kbas_GetSystemMetrics(int index) {
    return GetSystemMetrics(index);
}

/* ════════════════════════════════════════════════
   4. KLAVYE & FARE GİRİŞİ  (user32)
   ════════════════════════════════════════════════ */

/* Ham tuş durumu (bit 15 = şu an basılı) */
bool kbas_IsKeyPressed(int vKey) {
    return (GetAsyncKeyState(vKey) & 0x8000) != 0;
}

/* Tuş serbest bırakıldı mı (son kontolden bu yana)? */
bool kbas_WasKeyPressed(int vKey) {
    return (GetAsyncKeyState(vKey) & 0x0001) != 0;
}

/* Mesaj kuyruğu tabanlı tuş durumu */
bool kbas_GetKeyState(int vKey) {
    return (GetKeyState(vKey) & 0x8000) != 0;
}

/* Fare konumu (ekran koordinatı) */
int kbas_GetMouseX() {
    POINT p; GetCursorPos(&p); return (int)p.x;
}
int kbas_GetMouseY() {
    POINT p; GetCursorPos(&p); return (int)p.y;
}

/* İmleci konumlandır */
bool kbas_SetMousePos(int x, int y) {
    return (bool)SetCursorPos(x, y);
}

/* İmleç göster/gizle (-1 = hep gizle, >=0 = göster) */
int kbas_ShowMouseCursor(bool show) {
    return ShowCursor(show);
}

/* Fareyi bir dikdörtgenle kilitle */
bool kbas_ClipMouse(int l, int t, int r, int b) {
    RECT rc = {l, t, r, b};
    return (bool)ClipCursor(&rc);
}

/* Fare kilidini kaldır */
bool kbas_UnclipMouse() {
    return (bool)ClipCursor(NULL);
}

/* Çift tıklama süresi (ms) */
int kbas_GetDoubleClickTime() {
    return (int)GetDoubleClickTime();
}

/* Mouse sol/sağ düğme takası (true = takaslı) */
bool kbas_SwapMouseButton(bool swap) {
    return (bool)SwapMouseButton(swap);
}

/* Sanal tuş → karakter */
int kbas_VkToChar(int vKey) {
    return (int)MapVirtualKeyA((UINT)vKey, MAPVK_VK_TO_CHAR);
}

/* Karakter → sanal tuş */
int kbas_CharToVk(int ch) {
    return (int)(VkKeyScanA((char)ch) & 0xFF);
}

/* Programatik tuş basışı simüle et */
void kbas_SimKeyPress(int vKey) {
    keybd_event((BYTE)vKey, 0, 0, 0);
    keybd_event((BYTE)vKey, 0, KEYEVENTF_KEYUP, 0);
}

/* Programatik fare tıklaması simüle et */
void kbas_SimMouseClick(int x, int y) {
    SetCursorPos(x, y);
    mouse_event(MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0);
    mouse_event(MOUSEEVENTF_LEFTUP,   0, 0, 0, 0);
}

/* Programatik sağ tıklama */
void kbas_SimRightClick(int x, int y) {
    SetCursorPos(x, y);
    mouse_event(MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, 0);
    mouse_event(MOUSEEVENTF_RIGHTUP,   0, 0, 0, 0);
}

/* Fare tekerleği simüle et */
void kbas_SimMouseWheel(int delta) {
    mouse_event(MOUSEEVENTF_WHEEL, 0, 0, (DWORD)delta, 0);
}

/* ════════════════════════════════════════════════
   5. ZAMANLAMA  (kernel32 + winmm)
   ════════════════════════════════════════════════ */

int  kbas_GetTickCount() { return (int)GetTickCount(); }
void kbas_Sleep(int ms)  { Sleep((DWORD)ms); }

/* Yüksek çözünürlüklü sayaç - saniyeye böl */
double kbas_GetTime() {
    LARGE_INTEGER freq, now;
    QueryPerformanceFrequency(&freq);
    QueryPerformanceCounter(&now);
    return (double)now.QuadPart / (double)freq.QuadPart;
}

/* Yüksek çözünürlüklü ham sayaç */
int kbas_GetPerformanceCounter() {
    LARGE_INTEGER now;
    QueryPerformanceCounter(&now);
    return (int)(now.QuadPart & 0x7FFFFFFF);
}

/* Zamanlayıcı frekansı (tik/saniye) */
int kbas_GetPerformanceFrequency() {
    LARGE_INTEGER freq;
    QueryPerformanceFrequency(&freq);
    return (int)freq.QuadPart;
}

/* Multimedya zamanlayıcı (ms cinsinden sistem süresi) */
int kbas_TimeGetTime() {
    return (int)timeGetTime();
}

/* ════════════════════════════════════════════════
   6. DOSYA & DİZİN  (kernel32)
   ════════════════════════════════════════════════ */

/* Dosya var mı? */
bool kbas_FileExists(char* path) {
    DWORD attr = GetFileAttributesA(path);
    return (attr != INVALID_FILE_ATTRIBUTES && !(attr & FILE_ATTRIBUTE_DIRECTORY));
}

/* Dizin var mı? */
bool kbas_DirExists(char* path) {
    DWORD attr = GetFileAttributesA(path);
    return (attr != INVALID_FILE_ATTRIBUTES && (attr & FILE_ATTRIBUTE_DIRECTORY));
}

/* Dosya aç/oluştur; handle indeksi döner (-1 = hata) */
int kbas_OpenFile(char* path, int access, int shareMode, int creation) {
    HANDLE h = CreateFileA(path, (DWORD)access, (DWORD)shareMode,
                           NULL, (DWORD)creation, FILE_ATTRIBUTE_NORMAL, NULL);
    return kbas__alloc_handle(h);
}

/* Handle kapat */
bool kbas_CloseHandle(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return false;
    bool ok = (bool)CloseHandle(h);
    g_handles[hIdx] = NULL;
    return ok;
}

/* Dosyayı oku (max len bayt); okunan bayt sayısını döner */
int kbas_ReadFile(int hIdx, char* buf, int len) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return -1;
    DWORD read = 0;
    ReadFile(h, buf, (DWORD)len, &read, NULL);
    return (int)read;
}

/* Dosyaya yaz */
int kbas_WriteFile(int hIdx, char* buf, int len) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return -1;
    DWORD written = 0;
    WriteFile(h, buf, (DWORD)(len < 0 ? (int)strlen(buf) : len), &written, NULL);
    return (int)written;
}

/* Dosya imlecini konumlandır (from: 0=baş, 1=şimdiki, 2=son) */
int kbas_SetFilePointer(int hIdx, int offset, int from) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (int)SetFilePointer(h, (LONG)offset, NULL, (DWORD)from) : -1;
}

/* Dosya boyutu (bayt) */
int kbas_GetFileSize(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return -1;
    DWORD hi = 0;
    DWORD lo = GetFileSize(h, &hi);
    return (int)lo;
}

/* Dosya sonu mu? */
bool kbas_IsEOF(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return true;
    DWORD cur = SetFilePointer(h, 0, NULL, FILE_CURRENT);
    DWORD sz  = GetFileSize(h, NULL);
    return cur >= sz;
}

/* Kolay metin yaz */
bool kbas_WriteTextFile(char* path, char* text) {
    HANDLE h = CreateFileA(path, GENERIC_WRITE, 0, NULL,
                           CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
    if (h == INVALID_HANDLE_VALUE) return false;
    DWORD written;
    WriteFile(h, text, (DWORD)strlen(text), &written, NULL);
    CloseHandle(h);
    return true;
}

/* Kolay metin ekle */
bool kbas_AppendTextFile(char* path, char* text) {
    HANDLE h = CreateFileA(path, FILE_APPEND_DATA, 0, NULL,
                           OPEN_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
    if (h == INVALID_HANDLE_VALUE) return false;
    DWORD written;
    SetFilePointer(h, 0, NULL, FILE_END);
    WriteFile(h, text, (DWORD)strlen(text), &written, NULL);
    CloseHandle(h);
    return true;
}

/* Kolay metin oku (g_strbuf'a yazar) */
char* kbas_ReadTextFile(char* path) {
    HANDLE h = CreateFileA(path, GENERIC_READ, FILE_SHARE_READ,
                           NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    g_strbuf[0] = 0;
    if (h == INVALID_HANDLE_VALUE) return kbc_str_dup(g_strbuf);
    DWORD sz  = GetFileSize(h, NULL);
    DWORD toRead = sz < (DWORD)(KBAS_STRBUF_SIZE - 1) ? sz : (DWORD)(KBAS_STRBUF_SIZE - 1);
    DWORD read;
    ReadFile(h, g_strbuf, toRead, &read, NULL);
    g_strbuf[read] = 0;
    CloseHandle(h);
    return kbc_str_dup(g_strbuf);
}

/* Dosya sil */
bool kbas_DeleteFile(char* path) { return (bool)DeleteFileA(path); }

/* Dosya kopyala */
bool kbas_CopyFile(char* src, char* dst, bool failIfExists) {
    return (bool)CopyFileA(src, dst, failIfExists);
}

/* Dosya taşı / yeniden adlandır */
bool kbas_MoveFile(char* src, char* dst) { return (bool)MoveFileA(src, dst); }

/* Dizin oluştur */
bool kbas_CreateDir(char* path) { return (bool)CreateDirectoryA(path, NULL); }

/* Dizin sil (boş olmalı) */
bool kbas_RemoveDir(char* path) { return (bool)RemoveDirectoryA(path); }

/* Geçici klasör yolu */
char* kbas_GetTempPath() {
    GetTempPathA(KBAS_STRBUF_SIZE, g_strbuf);
    return kbc_str_dup(g_strbuf);
}

/* Geçici dosya adı oluştur */
char* kbas_GetTempFileName(char* prefix) {
    char tmp[MAX_PATH];
    GetTempPathA(MAX_PATH, tmp);
    GetTempFileNameA(tmp, prefix ? prefix : "kbas", 0, g_strbuf);
    return kbc_str_dup(g_strbuf);
}

/* Mevcut dizin */
char* kbas_GetCurrentDir() {
    GetCurrentDirectoryA(KBAS_STRBUF_SIZE, g_strbuf);
    return kbc_str_dup(g_strbuf);
}

bool kbas_SetCurrentDir(char* path) {
    return (bool)SetCurrentDirectoryA(path);
}

/* Dosya öznitelikleri */
int  kbas_GetFileAttributes(char* path) { return (int)GetFileAttributesA(path); }
bool kbas_SetFileAttributes(char* path, int attr) {
    return (bool)SetFileAttributesA(path, (DWORD)attr);
}

/* Tam yol */
char* kbas_GetFullPath(char* path) {
    GetFullPathNameA(path, KBAS_STRBUF_SIZE, g_strbuf, NULL);
    return kbc_str_dup(g_strbuf);
}

/* Dosyaları listele - FindFirstFile / FindNextFile sarmalı */
static WIN32_FIND_DATAA g_finddata;
static HANDLE g_find_handle = INVALID_HANDLE_VALUE;

bool kbas_FindFirst(char* pattern) {
    if (g_find_handle != INVALID_HANDLE_VALUE) FindClose(g_find_handle);
    g_find_handle = FindFirstFileA(pattern, &g_finddata);
    return g_find_handle != INVALID_HANDLE_VALUE;
}
bool kbas_FindNext() {
    return g_find_handle != INVALID_HANDLE_VALUE
        && (bool)FindNextFileA(g_find_handle, &g_finddata);
}
void kbas_FindClose2() {
    if (g_find_handle != INVALID_HANDLE_VALUE) {
        FindClose(g_find_handle);
        g_find_handle = INVALID_HANDLE_VALUE;
    }
}
char* kbas_FindGetName()     { return g_finddata.cFileName; }
int   kbas_FindGetSize()     { return (int)g_finddata.nFileSizeLow; }
bool  kbas_FindIsDir()       { return (g_finddata.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0; }
bool  kbas_FindIsReadOnly()  { return (g_finddata.dwFileAttributes & FILE_ATTRIBUTE_READONLY) != 0; }
bool  kbas_FindIsHidden()    { return (g_finddata.dwFileAttributes & FILE_ATTRIBUTE_HIDDEN) != 0; }

/* ════════════════════════════════════════════════
   7. SÜREÇ & İŞ PARÇACĞI  (kernel32 + shell32)
   ════════════════════════════════════════════════ */

int  kbas_GetCurrentProcessId() { return (int)GetCurrentProcessId(); }
int  kbas_GetCurrentThreadId()  { return (int)GetCurrentThreadId();  }

/* Bir süreci çalıştır */
int kbas_CreateProcess(char* path, char* args) {
    STARTUPINFOA si = {sizeof(si)};
    PROCESS_INFORMATION pi = {0};
    char cmdline[4096];
    snprintf(cmdline, sizeof(cmdline), "\"%s\" %s", path, args ? args : "");
    bool ok = (bool)CreateProcessA(NULL, cmdline, NULL, NULL, FALSE,
                                   0, NULL, NULL, &si, &pi);
    if (!ok) return -1;
    CloseHandle(pi.hThread);
    int idx = kbas__alloc_handle(pi.hProcess);
    return idx;
}

/* Süreci sonlandır */
bool kbas_TerminateProcess(int hIdx, int exitCode) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (bool)TerminateProcess(h, (UINT)exitCode) : false;
}

/* Süreç çıkış kodu */
int kbas_GetExitCode(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return -1;
    DWORD code = 0;
    GetExitCodeProcess(h, &code);
    return (int)code;
}

/* Belirtilen süre kadar bekle (ms; -1 = sonsuz) */
int kbas_WaitForProcess(int hIdx, int timeoutMs) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (int)WaitForSingleObject(h, (DWORD)timeoutMs) : -1;
}

/* Uygulamayı çıktıya aç (ShellExecute) */
bool kbas_ShellOpen(char* path) {
    return (INT_PTR)ShellExecuteA(NULL, "open", path, NULL, NULL, SW_SHOWNORMAL) > 32;
}

bool kbas_ShellRun(char* path, char* args) {
    return (INT_PTR)ShellExecuteA(NULL, "open", path, args, NULL, SW_SHOWNORMAL) > 32;
}

/* Mevcut çalışanın modül yolu */
char* kbas_GetModulePath() {
    GetModuleFileNameA(NULL, g_strbuf, KBAS_STRBUF_SIZE);
    return kbc_str_dup(g_strbuf);
}

/* Komut satırı */
char* kbas_GetCommandLine2() {
    strncpy(g_strbuf, GetCommandLineA(), KBAS_STRBUF_SIZE - 1);
    return kbc_str_dup(g_strbuf);
}

/* Uygulamayı sonlandır */
void kbas_ExitProcess(int code) { ExitProcess((UINT)code); }

/* Mutex oluştur */
int kbas_CreateMutex(char* name) {
    HANDLE h = CreateMutexA(NULL, FALSE, name && strlen(name) ? name : NULL);
    return kbas__alloc_handle(h);
}

/* Mutex al */
bool kbas_LockMutex(int hIdx, int timeoutMs) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (WaitForSingleObject(h, (DWORD)timeoutMs) == WAIT_OBJECT_0) : false;
}

/* Mutex bırak */
bool kbas_UnlockMutex(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (bool)ReleaseMutex(h) : false;
}

/* Event oluştur */
int kbas_CreateEvent(char* name, bool manualReset, bool initialState) {
    HANDLE h = CreateEventA(NULL, manualReset, initialState,
                            name && strlen(name) ? name : NULL);
    return kbas__alloc_handle(h);
}

bool kbas_SetEvent(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (bool)SetEvent(h) : false;
}

bool kbas_ResetEvent(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (bool)ResetEvent(h) : false;
}

bool kbas_WaitForEvent(int hIdx, int timeoutMs) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (WaitForSingleObject(h, (DWORD)timeoutMs) == WAIT_OBJECT_0) : false;
}

/* ════════════════════════════════════════════════
   8. BELLEK YÖNETİMİ  (kernel32)
   ════════════════════════════════════════════════ */

/* Yığın bellekten tahsis et */
int kbas_HeapAlloc(int size) {
    HANDLE h = HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, (SIZE_T)size);
    return kbas__alloc_handle(h);
}

bool kbas_HeapFree(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return false;
    bool ok = (bool)HeapFree(GetProcessHeap(), 0, h);
    g_handles[hIdx] = NULL;
    return ok;
}

/* Global bellek */
int kbas_GlobalAlloc(int size) {
    HANDLE h = GlobalAlloc(GMEM_ZEROINIT, (SIZE_T)size);
    return kbas__alloc_handle(h);
}

int kbas_GlobalSize2(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    return h ? (int)GlobalSize(h) : 0;
}

bool kbas_GlobalFree2(int hIdx) {
    HANDLE h = kbas__get_handle(hIdx);
    if (!h) return false;
    bool ok = (GlobalFree(h) == NULL);
    g_handles[hIdx] = NULL;
    return ok;
}

/* Toplam fiziksel RAM (MB) */
int kbas_GetTotalRAM() {
    MEMORYSTATUSEX ms = {sizeof(ms)};
    GlobalMemoryStatusEx(&ms);
    return (int)(ms.ullTotalPhys / (1024 * 1024));
}

/* Kullanılabilir RAM (MB) */
int kbas_GetFreeRAM() {
    MEMORYSTATUSEX ms = {sizeof(ms)};
    GlobalMemoryStatusEx(&ms);
    return (int)(ms.ullAvailPhys / (1024 * 1024));
}

/* RAM kullanım yüzdesi */
int kbas_GetRAMUsagePercent() {
    MEMORYSTATUSEX ms = {sizeof(ms)};
    GlobalMemoryStatusEx(&ms);
    return (int)ms.dwMemoryLoad;
}

/* Toplam sanal bellek (MB) */
int kbas_GetTotalVirtualMem() {
    MEMORYSTATUSEX ms = {sizeof(ms)};
    GlobalMemoryStatusEx(&ms);
    return (int)(ms.ullTotalVirtual / (1024 * 1024));
}

/* ════════════════════════════════════════════════
   9. KAYIT DEFTERİ  (advapi32)
   ════════════════════════════════════════════════ */

/* Kök anahtarları: 0=HKLM, 1=HKCU, 2=HKCR, 3=HKU, 4=HKCC */
static HKEY kbas__rootkey(int root) {
    switch (root) {
        case 0: return HKEY_LOCAL_MACHINE;
        case 1: return HKEY_CURRENT_USER;
        case 2: return HKEY_CLASSES_ROOT;
        case 3: return HKEY_USERS;
        case 4: return HKEY_CURRENT_CONFIG;
        default: return HKEY_CURRENT_USER;
    }
}

/* Anahtar aç (-1 = hata) */
int kbas_RegOpenKey(int root, char* subKey, bool write) {
    HKEY hKey;
    REGSAM access = KEY_READ | (write ? KEY_WRITE : 0);
    LSTATUS r = RegOpenKeyExA(kbas__rootkey(root), subKey, 0, access, &hKey);
    return (r == ERROR_SUCCESS) ? kbas__alloc_key(hKey) : -1;
}

/* Anahtar oluştur veya aç */
int kbas_RegCreateKey(int root, char* subKey) {
    HKEY hKey;
    LSTATUS r = RegCreateKeyExA(kbas__rootkey(root), subKey, 0, NULL,
                                REG_OPTION_NON_VOLATILE, KEY_ALL_ACCESS,
                                NULL, &hKey, NULL);
    return (r == ERROR_SUCCESS) ? kbas__alloc_key(hKey) : -1;
}

/* Anahtar kapat */
bool kbas_RegCloseKey(int kIdx) {
    HKEY k = kbas__get_key(kIdx);
    if (!k) return false;
    bool ok = (RegCloseKey(k) == ERROR_SUCCESS);
    g_regkeys[kIdx] = NULL;
    return ok;
}

/* String değer oku */
char* kbas_RegGetString(int kIdx, char* valueName) {
    HKEY k = kbas__get_key(kIdx);
    g_strbuf[0] = 0;
    if (!k) return kbc_str_dup(g_strbuf);
    DWORD type, sz = KBAS_STRBUF_SIZE;
    RegQueryValueExA(k, valueName, NULL, &type, (LPBYTE)g_strbuf, &sz);
    return kbc_str_dup(g_strbuf);
}

/* String değer yaz */
bool kbas_RegSetString(int kIdx, char* valueName, char* value) {
    HKEY k = kbas__get_key(kIdx);
    if (!k) return false;
    return RegSetValueExA(k, valueName, 0, REG_SZ,
                          (LPBYTE)value, (DWORD)(strlen(value) + 1)) == ERROR_SUCCESS;
}

/* DWORD değer oku */
int kbas_RegGetDword(int kIdx, char* valueName) {
    HKEY k = kbas__get_key(kIdx);
    if (!k) return 0;
    DWORD val, sz = sizeof(DWORD), type;
    RegQueryValueExA(k, valueName, NULL, &type, (LPBYTE)&val, &sz);
    return (int)val;
}

/* DWORD değer yaz */
bool kbas_RegSetDword(int kIdx, char* valueName, int value) {
    HKEY k = kbas__get_key(kIdx);
    if (!k) return false;
    DWORD v = (DWORD)value;
    return RegSetValueExA(k, valueName, 0, REG_DWORD, (LPBYTE)&v, sizeof(v)) == ERROR_SUCCESS;
}

/* Değer sil */
bool kbas_RegDeleteValue2(int kIdx, char* valueName) {
    HKEY k = kbas__get_key(kIdx);
    return k ? RegDeleteValueA(k, valueName) == ERROR_SUCCESS : false;
}

/* Alt anahtar sil */
bool kbas_RegDeleteKey2(int root, char* subKey) {
    return RegDeleteKeyA(kbas__rootkey(root), subKey) == ERROR_SUCCESS;
}

/* ════════════════════════════════════════════════
   10. PANO  (user32)
   ════════════════════════════════════════════════ */

bool kbas_OpenClipboard() {
    return (bool)OpenClipboard(NULL);
}

bool kbas_CloseClipboard2() {
    return (bool)CloseClipboard();
}

bool kbas_EmptyClipboard2() {
    return (bool)EmptyClipboard();
}

bool kbas_ClipboardHasText() {
    return (bool)IsClipboardFormatAvailable(CF_TEXT);
}

/* Pano'dan metin al */
char* kbas_GetClipboardText() {
    g_strbuf[0] = 0;
    if (!OpenClipboard(NULL)) return kbc_str_dup(g_strbuf);
    HANDLE h = GetClipboardData(CF_TEXT);
    if (h) {
        char* p = (char*)GlobalLock(h);
        if (p) {
            strncpy(g_strbuf, p, KBAS_STRBUF_SIZE - 1);
            GlobalUnlock(h);
        }
    }
    CloseClipboard();
    return kbc_str_dup(g_strbuf);
}

/* Pano'ya metin koy */
bool kbas_SetClipboardText(char* text) {
    if (!OpenClipboard(NULL)) return false;
    EmptyClipboard();
    SIZE_T len = strlen(text) + 1;
    HANDLE hMem = GlobalAlloc(GMEM_MOVEABLE, len);
    if (!hMem) { CloseClipboard(); return false; }
    memcpy(GlobalLock(hMem), text, len);
    GlobalUnlock(hMem);
    SetClipboardData(CF_TEXT, hMem);
    CloseClipboard();
    return true;
}

/* ════════════════════════════════════════════════
   11. MULTİMEDYA & SES  (winmm)
   ════════════════════════════════════════════════ */

/* .wav dosyası çal (asenkron) */
bool kbas_PlayWav(char* path) {
    return (bool)PlaySoundA(path, NULL, SND_FILENAME | SND_ASYNC);
}

/* .wav dosyası çal (senkron - bitene kadar bekle) */
bool kbas_PlayWavSync(char* path) {
    return (bool)PlaySoundA(path, NULL, SND_FILENAME | SND_SYNC);
}

/* Sesi durdur */
void kbas_StopSound() {
    PlaySoundA(NULL, NULL, 0);
}

/* Sistem sesi çal */
bool kbas_PlaySystemSound(char* alias) {
    return (bool)PlaySoundA(alias, NULL, SND_ALIAS | SND_ASYNC);
}

/* Bip sesi */
bool kbas_Beep2(int freq, int ms) {
    return (bool)Beep((DWORD)freq, (DWORD)ms);
}

/* MCI komutunu çalıştır (video/müzik kontrolü) */
char* kbas_MciSend(char* command) {
    mciSendStringA(command, g_strbuf, KBAS_STRBUF_SIZE, NULL);
    return kbc_str_dup(g_strbuf);
}

/* Dalga çıkış cihazı sayısı */
int kbas_GetWaveOutDevCount() {
    return (int)waveOutGetNumDevs();
}

/* ════════════════════════════════════════════════
   12. KABUK & ORTAM  (shell32 + kernel32)
   ════════════════════════════════════════════════ */

/* Ortam değişkeni oku */
char* kbas_GetEnv(char* name) {
    GetEnvironmentVariableA(name, g_strbuf, KBAS_STRBUF_SIZE);
