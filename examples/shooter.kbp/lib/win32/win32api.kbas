/* ════════════════════════════════════════════════
   13. KONSOL  (kernel32)
   ════════════════════════════════════════════════ */

bool kbas_AllocConsole2() { 
    FreeConsole();
    if (!AllocConsole()) return false;
    FILE* dummy;
    freopen_s(&dummy, "CONOUT$", "w", stdout);
    freopen_s(&dummy, "CONOUT$", "w", stderr);
    freopen_s(&dummy, "CONIN$", "r", stdin);
    HANDLE hOut = CreateFileA("CONOUT$", GENERIC_READ | GENERIC_WRITE, FILE_SHARE_READ | FILE_SHARE_WRITE, NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    HANDLE hIn = CreateFileA("CONIN$", GENERIC_READ | GENERIC_WRITE, FILE_SHARE_READ | FILE_SHARE_WRITE, NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hOut != INVALID_HANDLE_VALUE) SetStdHandle(STD_OUTPUT_HANDLE, hOut);
    if (hIn != INVALID_HANDLE_VALUE) SetStdHandle(STD_INPUT_HANDLE, hIn);
    return true;
}
bool kbas_FreeConsole2()  { return (bool)FreeConsole();  }

/* Konsol başlığı */
bool kbas_SetConsoleTitle2(char* title) {
    return (bool)SetConsoleTitleA(title);
}

/* Konsol başlığı oku */
char* kbas_GetConsoleTitle2() {
    GetConsoleTitleA(g_strbuf, KBAS_STRBUF_SIZE);
    return kbc_str_dup(g_strbuf);
}

/* Konsola yaz */
bool kbas_WriteConsole2(char* text) {
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    if (!h || h == INVALID_HANDLE_VALUE) return false;
    DWORD written;
    if (!WriteConsoleA(h, text, (DWORD)strlen(text), &written, NULL)) {
        return (bool)WriteFile(h, text, (DWORD)strlen(text), &written, NULL);
    }
    return true;
}

/* Konsoldan oku */
char* kbas_ReadConsole2(int maxLen) {
    HANDLE h = GetStdHandle(STD_INPUT_HANDLE);
    g_strbuf[0] = 0;
    if (!h || h == INVALID_HANDLE_VALUE) return kbc_str_dup(g_strbuf);
    DWORD read = 0;
    int n = maxLen < KBAS_STRBUF_SIZE - 1 ? maxLen : KBAS_STRBUF_SIZE - 1;
    if (!ReadConsoleA(h, g_strbuf, (DWORD)n, &read, NULL)) {
        if (!ReadFile(h, g_strbuf, (DWORD)n, &read, NULL)) {
            return kbc_str_dup(g_strbuf);
        }
    }
    g_strbuf[read] = 0;
    /* Satır sonu temizle */
    for (int i = (int)read - 1; i >= 0 && (g_strbuf[i]=='\n'||g_strbuf[i]=='\r'); i--)
        g_strbuf[i] = 0;
    return kbc_str_dup(g_strbuf);
}

bool kbas_strcmp(char* a, char* b) {
    if (!a || !b) return false;
    
    char bufA[256];
    char bufB[256];
    strncpy(bufA, a, 255); bufA[255] = '\0';
    strncpy(bufB, b, 255); bufB[255] = '\0';
    
    // a'nın sonundaki boşluk ve kontrol karakterlerini sil (trim right)
    int lenA = (int)strlen(bufA);
    while(lenA > 0 && bufA[lenA-1] <= 32) {
        bufA[lenA-1] = '\0';
        lenA--;
    }
    
    // b'nin sonundaki boşluk ve kontrol karakterlerini sil (trim right)
    int lenB = (int)strlen(bufB);
    while(lenB > 0 && bufB[lenB-1] <= 32) {
        bufB[lenB-1] = '\0';
        lenB--;
    }
    
    // Baştaki boşlukları atla (trim left)
    char* pA = bufA;
    while(*pA && *pA <= 32) pA++;
    
    char* pB = bufB;
    while(*pB && *pB <= 32) pB++;

    return strcmp(pA, pB) == 0;
}

/* İmleç konumu (satır, sütun) */
bool kbas_SetConsoleCursor(int x, int y) {
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    COORD c = {(SHORT)x, (SHORT)y};
    return h ? (bool)SetConsoleCursorPosition(h, c) : false;
}

/* Metin rengi (ön plan: 0-15, arka plan: 0-15) */
bool kbas_SetConsoleColor(int fg, int bg) {
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    if (!h || h == INVALID_HANDLE_VALUE) return false;
    return (bool)SetConsoleTextAttribute(h, (WORD)((bg << 4) | fg));
}

void kbas_MsgBox(char* text, char* title) {
    MessageBoxA(NULL, text, title, MB_OK | MB_ICONINFORMATION);
}

/* Konsol penceresini getir (hwnd indeks) */
int kbas_GetConsoleWindow2() {
    return kbas__alloc_hwnd(GetConsoleWindow());
}

