static void kbas__update_utc() { GetSystemTime(&kbas__utc); }
int kbas_GetUTCHour()   { kbas__update_utc(); return (int)kbas__utc.wHour; }
int kbas_GetUTCMinute() { kbas__update_utc(); return (int)kbas__utc.wMinute; }

